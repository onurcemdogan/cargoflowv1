# Yalnız ŞABLON değerlerdir; gerçek secret bu dosyaya YAZILMAZ/commitLENMEZ.
# Self-hosted (Ubuntu + PM2 + Nginx): bu dosyayı sunucuda proje kökünde
# ".env" olarak oluşturun (chmod 600). Uygulama başlarken kendisi okur.

# --- Çalışma ortamı ---
NODE_ENV=production
# Nginx reverse proxy arkasında yalnız localhost'u dinle (dışarı kapalı).
HOST=127.0.0.1
PORT=8787
# Nginx arkasında gerçek istemci IP'si (rate limit için). Uygulama doğrudan
# internete açıksa BU SATIRI EKLEMEYİN.
TRUST_PROXY=1

# --- PostgreSQL (aynı sunucuda) ---
# Localhost bağlantısı SSL istemez; sslmode eklemeyin.
DATABASE_URL=postgresql://cargoflow:PAROLA@127.0.0.1:5432/cargoflow

# --- Oturum ---
AUTH_SESSION_DAYS=7

# --- Şifreleme anahtarları (her biri 32 byte, base64 veya hex) ---
# Üretmek için: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
SHIPMENT_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
ORDER_DATA_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
PRODUCT_DATA_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>

# --- TEST MODU (varsayılan KAPALI) ---
# Açılırsa giriş ekranı atlanır; uygulama ve /admin paneli parolasız açılır.
# İstekler gerçek bir organization'a bağlanır (tenant izolasyonu bozulmaz).
# YALNIZ kendi test sunucunuzda kullanın; gerçek müşteri verisiyle AÇIK BIRAKMAYIN.
# Kapatmak: bu satırı silin + pm2 restart cargoflow
# CARGOFLOW_AUTH_BYPASS=true

# --- Opsiyonel ---
# Public self-servis kurulum production'da KAPALIDIR. Organization hesapları
# platform yöneticisi tarafından /admin panelinden oluşturulur.
# ALLOW_PUBLIC_BOOTSTRAP=false
# Sürat ağ hatalarında güvenli teşhis logu (secret/PII loglanmaz).
# SURAT_DEBUG=1
# Organization auth teşhis logu (token/hash loglanmaz).
# AUTH_DEBUG=1
