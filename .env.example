# Yalnız ŞABLON değerlerdir; gerçek secret bu dosyaya YAZILMAZ/commitLENMEZ.
# Railway'de bu değişkenler servis Variables ekranından sağlanır.
# PORT Railway tarafından otomatik verilir; burada sabitlenmesi gerekmez.
DATABASE_URL=postgresql://...
NODE_ENV=production
CREDENTIAL_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
SHIPMENT_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
ORDER_DATA_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
PRODUCT_DATA_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
AUTH_SESSION_DAYS=7
