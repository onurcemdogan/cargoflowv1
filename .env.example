# CargoFlow — self-hosted ortam değişkenleri ŞABLONU.
# Kullanım:  cp .env.example .env   → değerleri doldur → npm run setup:server
# Bu dosya ŞABLONDUR; gerçek secret buraya YAZILMAZ ve commit EDİLMEZ.
# Uygulama başlarken proje kökündeki .env dosyasını kendisi okur.
# Anahtar üretmek için:  openssl rand -base64 32

# --- Çalışma ortamı --------------------------------------------------------
NODE_ENV=production
# 0.0.0.0 = sunucunun tüm arayüzlerinden erişilebilir (IP:PORT ile test için).
# Nginx reverse proxy arkasına alınca 127.0.0.1 yapın.
HOST=0.0.0.0
PORT=8787
# Uygulamanın tarayıcıdan erişilen adresi (health/kurulum çıktısında kullanılır).
APP_URL=http://SERVER_IP:8787

# --- Reverse proxy / cookie -----------------------------------------------
# Nginx/proxy YOKKEN false bırakın. Nginx arkasında 1 yapın (gerçek istemci IP'si
# rate limit için X-Forwarded-For'dan okunur).
TRUST_PROXY=false
# HTTPS YOKKEN (http://IP:8787) MUTLAKA false olmalı: aksi halde tarayıcı Secure
# cookie'yi geri göndermez ve login başarılı görünse de 401 alırsınız.
# Domain + HTTPS'e geçince true yapın.
COOKIE_SECURE=false

# --- PostgreSQL (aynı sunucuda) -------------------------------------------
# Localhost bağlantısı SSL istemez; sslmode eklemeyin.
DATABASE_URL=postgresql://cargoflow:PAROLA@127.0.0.1:5432/cargoflow_db

# --- Oturum ----------------------------------------------------------------
AUTH_SESSION_DAYS=7
# Oturum altyapısı için ayrılmış gizli değer (zorunlu).
SESSION_SECRET=<32-byte-base64-or-hex-key>

# --- Şifreleme anahtarları (her biri 32 byte; base64 veya hex) -------------
CREDENTIAL_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
SHIPMENT_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
ORDER_DATA_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>
PRODUCT_DATA_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>

# --- Opsiyonel teşhis ------------------------------------------------------
# Organization auth teşhis logu (token/hash loglanmaz).
# AUTH_DEBUG=1
# Sürat ağ hatası teşhis logu (secret/PII loglanmaz).
# SURAT_DEBUG=1
# Public self-servis kurulum production'da KAPALIDIR; hesaplar platform
# yöneticisi tarafından /admin panelinden oluşturulur.
# ALLOW_PUBLIC_BOOTSTRAP=false
